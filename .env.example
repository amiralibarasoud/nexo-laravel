APP_NAME="نکسو کورس"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fa
APP_FALLBACK_LOCALE=fa
APP_FAKER_LOCALE=fa_IR
APP_TIMEZONE=Asia/Tehran

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# برای XAMPP: mysql | برای سرور: mysql
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexocourse
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# برای XAMPP: sync | برای سرور با Redis: redis
QUEUE_CONNECTION=sync

# برای XAMPP: file | برای سرور با Redis: redis
CACHE_STORE=file

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@nexocourse.ir"
MAIL_FROM_NAME="${APP_NAME}"

# ─── SMS.ir ───────────────────────────────────
# کلید API از پنل sms.ir
SMSIR_API_KEY=
# شناسه قالب OTP (پیش‌فرض: 238380)
SMSIR_OTP_TEMPLATE_ID=238380

# ─── درگاه‌های پرداخت ─────────────────────────
# زرین‌پال (فعلاً غیرفعال)
ZARINPAL_ENABLED=false
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true

# زیبال
ZIBAL_MERCHANT=zibal

VITE_APP_NAME="${APP_NAME}"
